{
  "name": "andrea-openai-bot",
  "version": "1.2.42",
  "description": "Andrea's standalone Codex/OpenAI-backed runtime bot with Podman-first local execution.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:agent-runner": "npm --prefix container/agent-runner run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "install:all": "npm install && npm --prefix container/agent-runner install",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:runtime": "vitest run src/agent-runtime.test.ts src/codex-home.test.ts src/container-runtime.test.ts src/container-runner.test.ts src/db-agent-threads.test.ts src/runtime-orchestration.test.ts src/runtime-commands.test.ts src/task-scheduler.test.ts src/operator-command-gate.test.ts src/ipc-auth.test.ts src/routing.test.ts setup/environment.test.ts setup/platform.test.ts setup/register.test.ts src/db.test.ts src/db-migration.test.ts",
    "validate:runtime": "tsx scripts/validate-runtime.ts",
    "generate:realworld-corpus": "node scripts/generate-realworld-corpus.mjs",
    "realworld:send:dry-run": "node scripts/realworld-send.mjs --dry-run",
    "realworld:send": "node scripts/realworld-send.mjs --send",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "22.x"
  }
}
